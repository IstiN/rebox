{
  "name": "rebox",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "REBOX_INTEGRATION=1 vitest run test/integration",
    "verify": "npm run build && REBOX_INTEGRATION=1 vitest run test/integration/rebox.integration.test.ts"
  },
  "dependencies": {
    "defuddle": "^0.14.0",
    "fastify": "^5.2.1",
    "playwright": "^1.50.1",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
