{
  "name": "rebox",
  "version": "0.5.0",
  "description": "Headless render microservice (text, screenshot, YouTube transcript) plus rebox CLI",
  "keywords": [
    "playwright",
    "scraper",
    "screenshot",
    "defuddle",
    "openapi",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IstiN/rebox.git"
  },
  "type": "module",
  "bin": {
    "rebox": "bin/rebox.mjs"
  },
  "files": [
    "bin",
    "dist",
    "openapi.yaml",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "cli": "npm run build && node bin/rebox.mjs",
    "cli:dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "REBOX_INTEGRATION=1 vitest run test/integration",
    "test:parallel": "REBOX_INTEGRATION=1 vitest run test/integration/parallel.integration.test.ts",
    "verify": "npm run build && REBOX_INTEGRATION=1 vitest run test/integration/rebox.integration.test.ts",
    "verify:all": "npm run build && REBOX_INTEGRATION=1 vitest run test/integration"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "commander": "^14.0.3",
    "defuddle": "^0.14.0",
    "fastify": "^5.2.1",
    "picocolors": "^1.1.1",
    "playwright": "^1.50.1",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
